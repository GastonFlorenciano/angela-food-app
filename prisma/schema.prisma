datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// 1. Roles del Sistema
enum Role {
  ADMIN
  CLIENTE
}

// 2. Estados del Pedido
enum OrderStatus {
  PENDIENTE
  EN_PREPARACION
  LISTO             // <- NUEVO ESTADO PARA RETIRO EN LOCAL
  EN_CAMINO
  ENTREGADO
  CANCELADO
}

// 3. Tabla de Usuarios (Principalmente para el Administrador)
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(CLIENTE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 4. Tabla de Productos (Menú de comidas)
model Product {
  id          String      @id @default(uuid())
  name        String
  description String
  price       Float
  imageUrl    String?
  category    String      // Ej: "Hamburguesas", "Bebidas", "Pizzas"
  isAvailable Boolean     @default(true)
  isFeatured  Boolean     @default(false) // <- NUEVO CAMPO PARA LOS PLATOS DESTACADOS
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

// 5. Tabla de Pedidos
model Order {
  id              String      @id @default(uuid())
  orderNumber     Int         @unique @default(autoincrement())
  customerName    String
  customerPhone   String
  deliveryAddress String
  deliveryZone    String
  paymentMethod   String
  notes           String?
  status          OrderStatus @default(PENDIENTE)
  total           Float
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
}

// 6. Detalle de los productos de cada pedido
model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

// 7. Tabla de Reseñas / Feedback
model Feedback {
  id            String   @id @default(uuid())
  customerName  String   @default("Anónimo")
  rating        Int
  comment       String
  adminResponse String?
  createdAt     DateTime @default(now())
}